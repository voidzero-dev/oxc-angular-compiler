{
  "name": "@oxc-angular/compare",
  "version": "0.1.0",
  "private": true,
  "description": "Compare oxc_angular_compiler output with @angular/compiler",
  "type": "module",
  "scripts": {
    "compare": "oxnode src/index.ts",
    "compare:full-file": "NODE_OPTIONS='--max-old-space-size=16384' oxnode src/index.ts --full-file",
    "compare:clickup": "NODE_OPTIONS='--max-old-space-size=32768' oxnode src/index.ts --preset clickup --full-file",
    "compare:clickup:fast": "NODE_OPTIONS='--max-old-space-size=16384' oxnode src/index.ts --preset clickup --full-file --ng-baseline ./ng-baseline-clickup.json",
    "compare:clickup:save-baseline": "NODE_OPTIONS='--max-old-space-size=32768' oxnode src/index.ts --preset clickup --full-file --generate-ng-baseline --save-ng-baseline ./ng-baseline-clickup.json",
    "show-diff": "oxnode src/show-diff.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "diff": "^8.0.2",
    "fast-glob": "^3.3.3",
    "p-limit": "^7.0.0",
    "rxjs": "catalog:",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@oxc-angular/vite": "workspace:*",
    "@oxc-node/cli": "catalog:",
    "@oxc-node/core": "catalog:",
    "@types/node": "catalog:",
    "oxc-parser": "^0.110.0",
    "oxc-transform": "^0.110.0",
    "oxfmt": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
