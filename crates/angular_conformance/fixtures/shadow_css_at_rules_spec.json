        {
          "name": "@page",
          "groups": [],
          "tests": [
            {
              "name": "should preserve @page rules",
              "path": "ShadowCss, at-rules/@page/should preserve @page rules",
              "assertions": []
            },
            {
              "name": "should strip ::ng-deep and :host from within @page rules",
              "path": "ShadowCss, at-rules/@page/should strip ::ng-deep and :host from within @page rules",
              "assertions": [
                {
                  "type": "ShimCss",
                  "input": "@page { margin-right: 4in; }",
                  "content_attr": "contenta",
                  "host_attr": "h",
                  "expected": "@page { margin-right:4in;}",
                  "normalized": true
                },
                {
                  "type": "ShimCss",
                  "input": "@page { ::ng-deep @top-left { content: \"Hamlet\";}}",
                  "content_attr": "contenta",
                  "host_attr": "h",
                  "expected": "@page { @top-left { content:\"Hamlet\";}}",
                  "normalized": true
                },
                {
                  "type": "ShimCss",
                  "input": "@page { :host ::ng-deep @top-left { content:\"Hamlet\";}}",
                  "content_attr": "contenta",
                  "host_attr": "h",
                  "expected": "@page { @top-left { content:\"Hamlet\";}}",
                  "normalized": true
                }
              ]
            }
          ]
        },
        {
          "name": "@supports",
          "groups": [],
          "tests": [
            {
              "name": "should handle support rules",
              "path": "ShadowCss, at-rules/@supports/should handle support rules",
              "assertions": []
            },
            {
              "name": "should strip ::ng-deep and :host from within @supports",
              "path": "ShadowCss, at-rules/@supports/should strip ::ng-deep and :host from within @supports",
              "assertions": [
                {
                  "type": "ShimCss",
                  "input": "@supports (display: flex) { @font-face { :host ::ng-deep font-family{} } }",
                  "content_attr": "contenta",
                  "host_attr": "h",
                  "expected": "@supports (display:flex) { @font-face { font-family{}}}",
                  "normalized": true
                }
              ]
            }
          ]
        },
        {
          "name": "@font-face",
          "groups": [],
          "tests": [
            {
              "name": "should strip ::ng-deep and :host from within @font-face",
              "path": "ShadowCss, at-rules/@font-face/should strip ::ng-deep and :host from within @font-face",
              "assertions": [
                {
                  "type": "ShimCss",
                  "input": "@font-face { font-family {} }",
                  "content_attr": "contenta",
                  "host_attr": "h",
                  "expected": "@font-face { font-family {}}",
                  "normalized": true
                },
                {
                  "type": "ShimCss",
                  "input": "@font-face { ::ng-deep font-family{} }",
                  "content_attr": "contenta",
                  "host_attr": "h",
                  "expected": "@font-face { font-family{}}",
                  "normalized": true
                },
                {
                  "type": "ShimCss",
                  "input": "@font-face { :host ::ng-deep font-family{} }",
                  "content_attr": "contenta",
                  "host_attr": "h",
                  "expected": "@font-face { font-family{}}",
                  "normalized": true
                }
              ]
            }
