{
  "name": "html_whitespaces_spec.ts",
  "file_path": "/Users/brooklyn/workspace/github/oxc-angular-compiler/crates/oxc_angular_compiler/angular/packages/compiler/test/ml_parser/html_whitespaces_spec.ts",
  "test_groups": [
    {
      "name": "removeWhitespaces",
      "groups": [],
      "tests": [
        {
          "name": "should remove blank text nodes",
          "path": "removeWhitespaces/should remove blank text nodes",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": " ",
              "expected": [],
              "options": null
            },
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "\n",
              "expected": [],
              "options": null
            },
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "\t",
              "expected": [],
              "options": null
            },
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "    \t    \n ",
              "expected": [],
              "options": null
            }
          ]
        },
        {
          "name": "should remove whitespaces (space, tab, new line) between elements",
          "path": "removeWhitespaces/should remove whitespaces (space, tab, new line) between elements",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "<br>  <br>\t<br>\n<br>",
              "expected": [
                [
                  "html.Element",
                  "br",
                  0.0
                ],
                [
                  "html.Element",
                  "br",
                  0.0
                ],
                [
                  "html.Element",
                  "br",
                  0.0
                ],
                [
                  "html.Element",
                  "br",
                  0.0
                ]
              ],
              "options": null
            }
          ]
        },
        {
          "name": "should remove whitespaces from child text nodes",
          "path": "removeWhitespaces/should remove whitespaces from child text nodes",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "<div><span> </span></div>",
              "expected": [
                [
                  "html.Element",
                  "div",
                  0.0
                ],
                [
                  "html.Element",
                  "span",
                  1.0
                ]
              ],
              "options": null
            }
          ]
        },
        {
          "name": "should remove whitespaces from the beginning and end of a template",
          "path": "removeWhitespaces/should remove whitespaces from the beginning and end of a template",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": " <br>\t",
              "expected": [
                [
                  "html.Element",
                  "br",
                  0.0
                ]
              ],
              "options": null
            }
          ]
        },
        {
          "name": "should convert &ngsp; to a space and preserve it",
          "path": "removeWhitespaces/should convert &ngsp; to a space and preserve it",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "<div><span>foo</span>&ngsp;<span>bar</span></div>",
              "expected": [
                [
                  "html.Element",
                  "div",
                  0.0
                ],
                [
                  "html.Element",
                  "span",
                  1.0
                ],
                [
                  "html.Text",
                  "foo",
                  2.0,
                  [
                    "foo"
                  ]
                ],
                [
                  "html.Text",
                  " ",
                  1.0,
                  [
                    ""
                  ],
                  [
                    "NGSP_UNICODE",
                    "&ngsp;"
                  ],
                  [
                    ""
                  ]
                ],
                [
                  "html.Element",
                  "span",
                  1.0
                ],
                [
                  "html.Text",
                  "bar",
                  2.0,
                  [
                    "bar"
                  ]
                ]
              ],
              "options": null
            }
          ]
        },
        {
          "name": "should replace multiple whitespaces with one space",
          "path": "removeWhitespaces/should replace multiple whitespaces with one space",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "\n\n\nfoo\t\t\t",
              "expected": [
                [
                  "html.Text",
                  " foo ",
                  0.0,
                  [
                    " foo "
                  ]
                ]
              ],
              "options": null
            },
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "   \n foo  \t ",
              "expected": [
                [
                  "html.Text",
                  " foo ",
                  0.0,
                  [
                    " foo "
                  ]
                ]
              ],
              "options": null
            }
          ]
        },
        {
          "name": "should remove whitespace inside of blocks",
          "path": "removeWhitespaces/should remove whitespace inside of blocks",
          "assertions": []
        },
        {
          "name": "should not replace &nbsp;",
          "path": "removeWhitespaces/should not replace &nbsp;",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "&nbsp;",
              "expected": [
                [
                  "html.Text",
                  " ",
                  0.0,
                  [
                    ""
                  ],
                  [
                    " ",
                    "&nbsp;"
                  ],
                  [
                    ""
                  ]
                ]
              ],
              "options": null
            }
          ]
        },
        {
          "name": "should not replace sequences of &nbsp;",
          "path": "removeWhitespaces/should not replace sequences of &nbsp;",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "&nbsp;&nbsp;foo&nbsp;&nbsp;",
              "expected": [
                [
                  "html.Text",
                  "  foo  ",
                  0.0,
                  [
                    ""
                  ],
                  [
                    " ",
                    "&nbsp;"
                  ],
                  [
                    ""
                  ],
                  [
                    " ",
                    "&nbsp;"
                  ],
                  [
                    "foo"
                  ],
                  [
                    " ",
                    "&nbsp;"
                  ],
                  [
                    ""
                  ],
                  [
                    " ",
                    "&nbsp;"
                  ],
                  [
                    ""
                  ]
                ]
              ],
              "options": null
            }
          ]
        },
        {
          "name": "should not replace single tab and newline with spaces",
          "path": "removeWhitespaces/should not replace single tab and newline with spaces",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "\nfoo",
              "expected": [
                [
                  "html.Text",
                  "\nfoo",
                  0.0,
                  [
                    "\nfoo"
                  ]
                ]
              ],
              "options": null
            },
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "\tfoo",
              "expected": [
                [
                  "html.Text",
                  "\tfoo",
                  0.0,
                  [
                    "\tfoo"
                  ]
                ]
              ],
              "options": null
            }
          ]
        },
        {
          "name": "should preserve single whitespaces between interpolations",
          "path": "removeWhitespaces/should preserve single whitespaces between interpolations",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "{{fooExp}} {{barExp}}",
              "expected": [
                [
                  "html.Text",
                  "{{fooExp}} {{barExp}}",
                  0.0,
                  [
                    ""
                  ],
                  [
                    "{{",
                    "fooExp",
                    "}}"
                  ],
                  [
                    " "
                  ],
                  [
                    "{{",
                    "barExp",
                    "}}"
                  ],
                  [
                    ""
                  ]
                ]
              ],
              "options": null
            },
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "{{fooExp}}\t{{barExp}}",
              "expected": [
                [
                  "html.Text",
                  "{{fooExp}}\t{{barExp}}",
                  0.0,
                  [
                    ""
                  ],
                  [
                    "{{",
                    "fooExp",
                    "}}"
                  ],
                  [
                    "\t"
                  ],
                  [
                    "{{",
                    "barExp",
                    "}}"
                  ],
                  [
                    ""
                  ]
                ]
              ],
              "options": null
            },
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "{{fooExp}}\n{{barExp}}",
              "expected": [
                [
                  "html.Text",
                  "{{fooExp}}\n{{barExp}}",
                  0.0,
                  [
                    ""
                  ],
                  [
                    "{{",
                    "fooExp",
                    "}}"
                  ],
                  [
                    "\n"
                  ],
                  [
                    "{{",
                    "barExp",
                    "}}"
                  ],
                  [
                    ""
                  ]
                ]
              ],
              "options": null
            }
          ]
        },
        {
          "name": "should preserve whitespaces around interpolations",
          "path": "removeWhitespaces/should preserve whitespaces around interpolations",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": " {{exp}} ",
              "expected": [
                [
                  "html.Text",
                  " {{exp}} ",
                  0.0,
                  [
                    " "
                  ],
                  [
                    "{{",
                    "exp",
                    "}}"
                  ],
                  [
                    " "
                  ]
                ]
              ],
              "options": null
            }
          ]
        },
        {
          "name": "should preserve whitespaces around ICU expansions",
          "path": "removeWhitespaces/should preserve whitespaces around ICU expansions",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "<span> {a, b, =4 {c}} </span>",
              "expected": [
                [
                  "html.Element",
                  "span",
                  0.0
                ],
                [
                  "html.Text",
                  " ",
                  1.0,
                  [
                    " "
                  ]
                ],
                [
                  "html.Expansion",
                  "a",
                  "b",
                  1.0
                ],
                [
                  "html.ExpansionCase",
                  "=4",
                  2.0
                ],
                [
                  "html.Text",
                  " ",
                  1.0,
                  [
                    " "
                  ]
                ]
              ],
              "options": {
                "tokenize_expansion_forms": true,
                "interpolation_config": null,
                "escaped_string": false,
                "tokenize_blocks": null,
                "leading_trivia_chars": null,
                "range": null
              }
            }
          ]
        },
        {
          "name": "should preserve whitespaces inside <pre> elements",
          "path": "removeWhitespaces/should preserve whitespaces inside <pre> elements",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "<pre><strong>foo</strong>\n<strong>bar</strong></pre>",
              "expected": [
                [
                  "html.Element",
                  "pre",
                  0.0
                ],
                [
                  "html.Element",
                  "strong",
                  1.0
                ],
                [
                  "html.Text",
                  "foo",
                  2.0,
                  [
                    "foo"
                  ]
                ],
                [
                  "html.Text",
                  "\n",
                  1.0,
                  [
                    "\n"
                  ]
                ],
                [
                  "html.Element",
                  "strong",
                  1.0
                ],
                [
                  "html.Text",
                  "bar",
                  2.0,
                  [
                    "bar"
                  ]
                ]
              ],
              "options": null
            }
          ]
        },
        {
          "name": "should skip whitespace trimming in <textarea>",
          "path": "removeWhitespaces/should skip whitespace trimming in <textarea>",
          "assertions": [
            {
              "type": "ParseAndRemoveWhitespace",
              "input": "<textarea>foo\n\n  bar</textarea>",
              "expected": [
                [
                  "html.Element",
                  "textarea",
                  0.0
                ],
                [
                  "html.Text",
                  "foo\n\n  bar",
                  1.0,
                  [
                    "foo\n\n  bar"
                  ]
                ]
              ],
              "options": null
            }
          ]
        },
        {
          "name": "unnamed",
          "path": "removeWhitespaces/unnamed",
          "assertions": []
        }
      ]
    }
  ]
}