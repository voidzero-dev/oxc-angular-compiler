{
  "name": "ast_serializer_spec.ts",
  "file_path": "/Users/brooklyn/workspace/github/oxc-angular-compiler/crates/oxc_angular_compiler/angular/packages/compiler/test/ml_parser/ast_serializer_spec.ts",
  "test_groups": [
    {
      "name": "Node serializer",
      "groups": [],
      "tests": [
        {
          "name": "should support element",
          "path": "Node serializer/should support element",
          "assertions": [
            {
              "type": "SerializeNodes",
              "input": "<p></p>",
              "expected": [
                "<p></p>"
              ]
            }
          ]
        },
        {
          "name": "should support attributes",
          "path": "Node serializer/should support attributes",
          "assertions": [
            {
              "type": "SerializeNodes",
              "input": "<p k=\"value\"></p>",
              "expected": [
                "<p k=\"value\"></p>"
              ]
            }
          ]
        },
        {
          "name": "should support text",
          "path": "Node serializer/should support text",
          "assertions": [
            {
              "type": "SerializeNodes",
              "input": "some text",
              "expected": [
                "some text"
              ]
            }
          ]
        },
        {
          "name": "should support expansion",
          "path": "Node serializer/should support expansion",
          "assertions": [
            {
              "type": "SerializeNodes",
              "input": "{number, plural, =0 {none} =1 {one} other {many}}",
              "expected": [
                "{number, plural, =0 {none} =1 {one} other {many}}"
              ]
            }
          ]
        },
        {
          "name": "should support comment",
          "path": "Node serializer/should support comment",
          "assertions": [
            {
              "type": "SerializeNodes",
              "input": "<!--comment-->",
              "expected": [
                "<!--comment-->"
              ]
            }
          ]
        },
        {
          "name": "should support nesting",
          "path": "Node serializer/should support nesting",
          "assertions": [
            {
              "type": "SerializeNodes",
              "input": "<div i18n=\"meaning|desc\">\n        <span>{{ interpolation }}</span>\n        <!--comment-->\n        <p expansion=\"true\">\n          {number, plural, =0 {{sex, select, other {<b>?</b>}}}}\n        </p>\n      </div>",
              "expected": [
                "<div i18n=\"meaning|desc\">\n        <span>{{ interpolation }}</span>\n        <!--comment-->\n        <p expansion=\"true\">\n          {number, plural, =0 {{sex, select, other {<b>?</b>}}}}\n        </p>\n      </div>"
              ]
            }
          ]
        }
      ]
    }
  ]
}