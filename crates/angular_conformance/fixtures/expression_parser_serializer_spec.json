  "test_groups": [
    {
      "name": "serializer",
      "groups": [
        {
          "name": "serialize",
          "groups": [],
          "tests": [
            {
              "name": "serializes unary plus",
              "path": "serializer/serialize/serializes unary plus",
              "assertions": [
                {
                  "type": "SerializeExpression",
                  "input": " + 1234 ",
                  "expected": "+1234"
                }
              ]
            },
            {
              "name": "serializes unary negative",
              "path": "serializer/serialize/serializes unary negative",
              "assertions": [
                {
                  "type": "SerializeExpression",
                  "input": " - 1234 ",
                  "expected": "-1234"
                }
              ]
            },
            {
              "name": "serializes binary operations",
              "path": "serializer/serialize/serializes binary operations",
              "assertions": [
                {
                  "type": "SerializeExpression",
                  "input": " 1234   +   4321 ",
                  "expected": "1234 + 4321"
                }
              ]
            },
            {
              "name": "serializes exponentiation",
              "path": "serializer/serialize/serializes exponentiation",
              "assertions": [
                {
                  "type": "SerializeExpression",
                  "input": " 1  *  2  **  3 ",
                  "expected": "1 * 2 ** 3"
                }
              ]
            },
            {
              "name": "serializes chains",
              "path": "serializer/serialize/serializes chains",
              "assertions": [
                {
                  "type": "SerializeExpression",
                  "input": " 1234;   4321 ",
                  "expected": "1234; 4321"
                }
              ]
