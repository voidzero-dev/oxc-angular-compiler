            {
              "type": "ShimCss",
              "input": ":host(create-first-project) {}",
              "content_attr": "contenta",
              "host_attr": "hosta",
              "expected": "create-first-project[hosta] {}",
              "normalized": true
            },
            {
              "type": "ShimCss",
              "input": ":host[attr] {}",
              "content_attr": "contenta",
              "host_attr": "hosta",
