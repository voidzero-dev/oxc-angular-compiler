              "input": ":host[attr]:where(:not(.cm-button)) {}",
              "content_attr": "contenta",
              "host_attr": "hosta",
              "expected": "[attr][hosta]:where(:not(.cm-button)) {}",
              "normalized": true
            }
          ]
