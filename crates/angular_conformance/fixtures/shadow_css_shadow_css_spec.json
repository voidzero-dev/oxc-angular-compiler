        {
          "name": "should transform :host with attributes",
          "path": "ShadowCss/should transform :host with attributes",
          "assertions": [
            {
              "type": "ShimCss",
              "input": ":host [attr] {}",
              "content_attr": "contenta",
              "host_attr": "hosta",
