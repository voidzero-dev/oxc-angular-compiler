{
  "name": "shadow_css_spec.ts",
  "file_path": "crates/oxc_angular_compiler/angular/packages/compiler/test/shadow_css/shadow_css_spec.ts",
  "test_groups": [
    {
      "name": "ShadowCss",
      "groups": [
        {
          "name": "comments",
          "groups": [],
          "tests": [
            {
              "name": "should remove inline comments without adding extra lines",
              "path": "ShadowCss/comments/should remove inline comments without adding extra lines",
              "assertions": [
                {
                  "type": "ShimCss",
                  "input": "/* b {} */ b {}",
                  "content_attr": "contenta",
                  "host_attr": null,
                  "expected": " b[contenta] {}",
                  "normalized": false
                }
              ]
            },
            {
              "name": "should preserve internal newlines from multiline comments",
              "path": "ShadowCss/comments/should preserve internal newlines from multiline comments",
              "assertions": [
                {
                  "type": "ShimCss",
                  "input": "/* b {}\n */ b {}",
                  "content_attr": "contenta",
                  "host_attr": null,
                  "expected": "\n b[contenta] {}",
                  "normalized": false
                }
              ]
            },
            {
              "name": "should remove multiple inline comments without adding extra lines",
              "path": "ShadowCss/comments/should remove multiple inline comments without adding extra lines",
              "assertions": [
                {
                  "type": "ShimCss",
                  "input": "/* b {} */ b {} /* a {} */ a {}",
                  "content_attr": "contenta",
                  "host_attr": null,
                  "expected": " b[contenta] {}  a[contenta] {}",
                  "normalized": false
                }
              ]
            },
            {
              "name": "should keep sourceMappingURL comments",
              "path": "ShadowCss/comments/should keep sourceMappingURL comments",
              "assertions": [
                {
                  "type": "ShimCss",
                  "input": "b {} /*# sourceMappingURL=data:x */",
                  "content_attr": "contenta",
                  "host_attr": null,
                  "expected": "b[contenta] {} /*# sourceMappingURL=data:x */",
                  "normalized": false
                },
                {
                  "type": "ShimCss",
                  "input": "b {}/* #sourceMappingURL=data:x */",
                  "content_attr": "contenta",
                  "host_attr": null,
                  "expected": "b[contenta] {}/* #sourceMappingURL=data:x */",
                  "normalized": false
                }
              ]
            },
            {
              "name": "should handle adjacent comments",
              "path": "ShadowCss/comments/should handle adjacent comments",
              "assertions": [
                {
                  "type": "ShimCss",
                  "input": "/* comment 1 */ /* comment 2 */ b {}",
                  "content_attr": "contenta",
                  "host_attr": null,
                  "expected": "  b[contenta] {}",
                  "normalized": false
                }
              ]
            }
          ]
        }
      ],
